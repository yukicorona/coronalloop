---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<style>
/* ===================================
   Table of Contents
=================================== */
.toc-wrap {
  margin: 0 0 1.75rem;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: #fafafa;
  font-size: 0.9rem;
}

.toc-title {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.6rem 1rem;
  font-weight: 700;
  cursor: pointer;
  user-select: none;
  list-style: none;
  border-bottom: 1px solid transparent;
}

.toc-wrap[open] .toc-title {
  border-bottom-color: var(--color-border);
}

.toc-title::-webkit-details-marker { display: none; }

.toc-title::before {
  content: '▶';
  font-size: 0.65em;
  transition: transform 0.15s;
}

.toc-wrap[open] .toc-title::before {
  transform: rotate(90deg);
}

.toc-nav {
  padding: 0.6rem 1rem 0.75rem;
}

.toc-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.toc-item {
  margin: 0;
  line-height: 1.5;
}

.toc-item + .toc-item {
  margin-top: 0.25rem;
}

.toc-h3 {
  padding-left: 1.25rem;
}

.toc-link {
  color: var(--color-link);
  text-decoration: none;
  font-size: 0.875rem;
  display: inline-block;
  padding: 0.1em 0;
  border-bottom: 1px solid transparent;
  transition: color 0.1s;
}

.toc-link:hover {
  text-decoration: underline;
}

.toc-link--active {
  color: var(--color-text);
  font-weight: 600;
}
</style>

{toc.length >= 3 && (
  <details class="toc-wrap" open>
    <summary class="toc-title">目次</summary>
    <nav class="toc-nav" aria-label="目次">
      <ol class="toc-list">
        {toc.map(h => (
          <li class={`toc-item toc-h${h.depth}`}>
            <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
)}

<script>
  (function () {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-nav .toc-link');
    if (links.length === 0) return;

    const ids = Array.from(links).map(a => a.getAttribute('href')!.slice(1));
    const els = ids.map(id => document.getElementById(id)).filter((el): el is HTMLElement => el !== null);

    function update() {
      const y = window.scrollY + 90;
      let activeIdx = 0;
      for (let i = 0; i < els.length; i++) {
        if (els[i].offsetTop <= y) activeIdx = i;
      }
      links.forEach((link, i) => link.classList.toggle('toc-link--active', i === activeIdx));
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
