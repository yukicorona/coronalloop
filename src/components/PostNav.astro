---
interface NavPost {
  slug: string;
  data: { title: string };
}

interface Props {
  prevPost: NavPost | null;
  nextPost: NavPost | null;
  relatedPosts: NavPost[];
  currentCategory: string;
}

const { prevPost, nextPost, relatedPosts, currentCategory } = Astro.props;
---

<style>
/* ===================================
   Post Navigation (prev / next / related)
=================================== */
.post-nav {
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 2px solid var(--color-border-light);
}

.post-nav-arrows {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 1.75rem;
}

.post-nav-link {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: 0.75rem 1rem;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  text-decoration: none;
  background: #fafafa;
  transition: background 0.15s, border-color 0.15s;
  min-width: 0;
}

.post-nav-link:not(.post-nav-empty):hover {
  background: #f0f4f8;
  border-color: var(--color-link);
  text-decoration: none;
}

.post-nav-empty {
  background: none;
  border: none;
  pointer-events: none;
}

.post-nav-prev { align-items: flex-start; }
.post-nav-next { align-items: flex-end; text-align: right; }

.post-nav-dir {
  font-size: 0.78rem;
  color: var(--color-text-muted);
  font-weight: 500;
}

.post-nav-title {
  font-size: 0.88rem;
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-posts {
  background: #fafafa;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  padding: 1rem 1.25rem;
}

.related-posts-heading {
  font-size: 0.9rem;
  font-weight: 700;
  margin: 0 0 0.75rem;
  color: var(--color-text);
  border: none;
  padding: 0;
}

.related-posts-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.related-posts-item a {
  font-size: 0.9rem;
  color: var(--color-link);
  text-decoration: none;
}

.related-posts-item a:hover {
  text-decoration: underline;
}

@media (max-width: 600px) {
  .post-nav-arrows {
    flex-direction: column;
  }

  .post-nav-next {
    align-items: flex-start;
    text-align: left;
  }
}
</style>

<div class="post-nav">
  <div class="post-nav-arrows">
    {prevPost ? (
      <a href={`/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
        <span class="post-nav-dir">← 前の記事</span>
        <span class="post-nav-title">{prevPost.data.title}</span>
      </a>
    ) : (
      <span class="post-nav-link post-nav-empty" aria-hidden="true"></span>
    )}
    {nextPost ? (
      <a href={`/${nextPost.slug}/`} class="post-nav-link post-nav-next">
        <span class="post-nav-dir">次の記事 →</span>
        <span class="post-nav-title">{nextPost.data.title}</span>
      </a>
    ) : (
      <span class="post-nav-link post-nav-empty" aria-hidden="true"></span>
    )}
  </div>

  {relatedPosts.length > 0 && currentCategory && (
    <div class="related-posts">
      <h3 class="related-posts-heading">「{currentCategory}」の関連記事</h3>
      <ul class="related-posts-list">
        {relatedPosts.map(post => (
          <li class="related-posts-item">
            <a href={`/${post.slug}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
