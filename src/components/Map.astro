---
// Map.astro: Leafletマップコンポーネント
import 'leaflet/dist/leaflet.css';

// - propsでconfigを渡した場合: 指定configのマップを描画
// - propsなしの場合: ページ内の全 .leaflet-map-container を初期化
interface LeafletLayerConfig { type: 'kml' | 'gpx'; src: string; color?: string; }
interface LeafletMarkerConfig { lat: number; lng: number; label?: string; }
interface LeafletMapConfig {
  fitbounds?: boolean;
  zoomcontrol?: boolean;
  height?: number;
  layers?: LeafletLayerConfig[];
  markers?: LeafletMarkerConfig[];
  elevation?: { src: string } | null;
}
interface Props { config?: LeafletMapConfig; }
const { config } = Astro.props;
---

{config && (
  <div
    class="leaflet-map-container w-full rounded-lg overflow-hidden border border-gray-200"
    data-leaflet-config={JSON.stringify(config)}
    style={`height: ${config.height ?? 450}px`}
  ></div>
)}

<script>
  // ページ内の全 .leaflet-map-container を初期化
  const runInit = async () => {
    // コンテナが存在するか確認
    const containers = document.querySelectorAll('.leaflet-map-container');
    if (containers.length === 0) return;

    try {
      const { initLeafletMaps } = await import('../scripts/leaflet-init');
      await initLeafletMaps();
    } catch (err) {
      console.error('Failed to initialize Leaflet maps:', err);
    }
  };

  // すでにDOMが準備できている場合は即時実行、そうでなければイベントを待つ
  if (document.readyState !== 'loading') {
    runInit();
  } else {
    // load だと遅すぎる場合があるため DOMContentLoaded を優先し、
    //念のため load もフォールバックとして設定
    window.addEventListener('DOMContentLoaded', runInit);
    window.addEventListener('load', runInit);
  }

  // Astro View Transitions を使用している場合の対応
  document.addEventListener('astro:page-load', runInit);
</script>
