---
import { getCollection } from 'astro:content';
import { toSlug } from '../utils/taxonomy';

const allEntries = await getCollection('blog', ({ data }) => !data.draft);
const posts = allEntries.filter(e => e.data.type === 'post');

// カテゴリ: 記事数降順
const categoryCount = new Map<string, number>();
for (const post of posts) {
  for (const cat of post.data.categories ?? []) {
    categoryCount.set(cat, (categoryCount.get(cat) ?? 0) + 1);
  }
}
const categories = [...categoryCount.entries()]
  .filter(([, n]) => n > 0)
  .sort((a, b) => b[1] - a[1]);

// タグ: 記事数降順
const tagCount = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCount.entries()]
  .filter(([, n]) => n > 0)
  .sort((a, b) => b[1] - a[1]);
---

<style is:global>
/* ===================================
   Sidebar
=================================== */
.sidebar {
  position: sticky;
  top: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

@media (max-width: 900px) {
  .sidebar {
    position: static;
  }
}

.sidebar-widget {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 2px;
  overflow: hidden;
}

.sidebar-widget-title {
  font-size: 0.875rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  margin: 0;
  padding: 0.55rem 0.875rem;
  background: var(--color-header-nav);
  color: #ffffff;
  border-bottom: none;
}

/* サイト内検索 */
.sidebar-search-body {
  padding: 0.6rem 0.75rem 0.5rem;
}

.sidebar-search-input {
  width: 100%;
  padding: 0.4rem 0.65rem;
  font-size: 0.825rem;
  font-family: var(--font-body);
  border: 1px solid var(--color-border);
  border-radius: 3px;
  outline: none;
  background: var(--color-white);
  color: var(--color-text);
  box-sizing: border-box;
}

.sidebar-search-input:focus {
  border-color: var(--color-header-nav);
  box-shadow: 0 0 0 2px rgba(199, 0, 11, 0.15);
}

.sidebar-search-results {
  list-style: none;
  margin: 0;
  padding: 0;
  border-top: 1px solid var(--color-border-light);
  max-height: 320px;
  overflow-y: auto;
}

.sidebar-search-results li {
  border-bottom: 1px solid var(--color-border-light);
}

.sidebar-search-results li:last-child {
  border-bottom: none;
}

.sidebar-search-result-link {
  display: block;
  padding: 0.45rem 0.875rem;
  font-size: 0.8rem;
  color: var(--color-text);
  text-decoration: none;
  line-height: 1.45;
  transition: background 0.12s;
}

.sidebar-search-result-link:hover {
  background: #fff5f5;
  color: var(--color-header-nav);
}

.sidebar-search-empty {
  padding: 0.5rem 0.875rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.search-highlight {
  background: #ffe066;
  color: inherit;
  padding: 0 1px;
}

/* カテゴリリスト */
.sidebar-cat-list {
  list-style: none;
  margin: 0;
  padding: 0.25rem 0;
}

.sidebar-cat-list li {
  border-bottom: 1px solid var(--color-border-light);
}

.sidebar-cat-list li:last-child {
  border-bottom: none;
}

.sidebar-cat-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.45rem 0.875rem;
  font-size: 0.8rem;
  color: var(--color-text);
  text-decoration: none;
  transition: background 0.15s;
  gap: 0.5rem;
}

.sidebar-cat-link:hover {
  background: var(--color-bg);
  color: var(--color-link);
}

.sidebar-cat-link:hover .sidebar-cat-name {
  text-decoration: underline;
}

.sidebar-cat-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-cat-count {
  flex-shrink: 0;
  background: #e5e7eb;
  color: #6b7280;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.1em 0.45em;
  border-radius: 10px;
  min-width: 1.4em;
  text-align: center;
}

/* タグクラウド */
.sidebar-tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  padding: 0.75rem 0.75rem;
}

.sidebar-tag {
  display: inline-block;
  background: var(--color-tag-bg);
  color: var(--color-text);
  font-size: 0.75rem;
  padding: 0.2em 0.55em;
  border-radius: 2px;
  text-decoration: none;
  border: 1px solid var(--color-border);
  transition: background 0.15s, color 0.15s;
  line-height: 1.6;
}

.sidebar-tag:hover {
  background: var(--color-header-nav);
  color: #ffffff;
  border-color: var(--color-header-nav);
}
</style>

<aside class="sidebar" aria-label="サイドバー">

  <!-- サイト内検索 -->
  <section class="sidebar-widget sidebar-search-widget">
    <h2 class="sidebar-widget-title">サイト内検索</h2>
    <div class="sidebar-search-body">
      <input
        type="search"
        id="sidebar-search-input"
        class="sidebar-search-input"
        placeholder="キーワードを入力..."
        autocomplete="off"
        aria-label="サイト内検索"
      />
      <ul class="sidebar-search-results" id="sidebar-search-results" hidden></ul>
    </div>
  </section>

  <!-- カテゴリ一覧 -->
  <section class="sidebar-widget">
    <h2 class="sidebar-widget-title">カテゴリ</h2>
    <ul class="sidebar-cat-list">
      {categories.map(([name, count]) => (
        <li>
          <a href={`/category/${toSlug(name)}/`} class="sidebar-cat-link">
            <span class="sidebar-cat-name">{name}</span>
            <span class="sidebar-cat-count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- タグ一覧 -->
  <section class="sidebar-widget">
    <h2 class="sidebar-widget-title">タグ</h2>
    <div class="sidebar-tag-cloud">
      {tags.map(([name, count]) => (
        <a href={`/tag/${toSlug(name)}/`} class="sidebar-tag" title={`${count}件`}>
          {name}
        </a>
      ))}
    </div>
  </section>

</aside>

<script>
(function () {
  let index: Array<{ title: string; slug: string; excerpt: string; categories: string[]; tags: string[] }> | null = null;

  const input = document.getElementById('sidebar-search-input') as HTMLInputElement | null;
  const results = document.getElementById('sidebar-search-results') as HTMLUListElement | null;
  if (!input || !results) return;

  async function loadIndex() {
    if (index) return;
    try {
      const res = await fetch('/search.json');
      index = await res.json();
    } catch {
      index = [];
    }
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function highlight(text: string, query: string) {
    const safe = escapeHtml(text);
    const re = new RegExp(query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
    return safe.replace(re, m => `<mark class="search-highlight">${escapeHtml(m)}</mark>`);
  }

  function renderResults(query: string) {
    if (!index || query.length < 1) { results!.hidden = true; return; }
    const q = query.toLowerCase();
    const matched = index.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.excerpt.toLowerCase().includes(q) ||
      p.categories.some(c => c.toLowerCase().includes(q)) ||
      p.tags.some(t => t.toLowerCase().includes(q))
    ).slice(0, 7);

    if (matched.length === 0) {
      results!.innerHTML = '<li class="sidebar-search-empty">見つかりませんでした</li>';
    } else {
      results!.innerHTML = matched.map(p =>
        `<li><a href="/${p.slug}/" class="sidebar-search-result-link">${highlight(p.title, query)}</a></li>`
      ).join('');
    }
    results!.hidden = false;
  }

  let timer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', async () => {
    clearTimeout(timer);
    const q = input!.value.trim();
    if (q.length < 1) { results!.hidden = true; return; }
    await loadIndex();
    timer = setTimeout(() => renderResults(q), 180);
  });

  input.addEventListener('focus', async () => {
    const q = input!.value.trim();
    if (q.length >= 1) { await loadIndex(); renderResults(q); }
  });

  document.addEventListener('click', e => {
    if (!(e.target as Element).closest('.sidebar-search-widget')) {
      results!.hidden = true;
    }
  });
})();
</script>
