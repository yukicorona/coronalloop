---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/date';
import { toSlug } from '../../utils/taxonomy';
import { r2ThumbUrl } from '../../utils/images';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog', ({ data }) => !data.draft);
  const posts = allEntries
    .filter(e => e.data.type === 'post')
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const categoryMap = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const cat of (post.data.categories ?? [])) {
      if (!categoryMap.has(cat)) categoryMap.set(cat, []);
      categoryMap.get(cat)!.push(post);
    }
  }

  return [...categoryMap.entries()].map(([categoryName, catPosts]) => ({
    params: { category: toSlug(categoryName) },
    props: { categoryName, posts: catPosts },
  }));
}

const { categoryName, posts } = Astro.props;

const siteUrl = 'https://coronalloop.jp';
const pageUrl = `${siteUrl}/category/${toSlug(categoryName)}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${categoryName}の記事一覧`,
  url: pageUrl,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: categoryName, item: pageUrl },
    ],
  },
});
---

<BaseLayout
  title={`${categoryName}の記事一覧`}
  description={`「${categoryName}」カテゴリの記事一覧（${posts.length}件）`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <nav class="breadcrumb" aria-label="パンくず">
    <ol>
      <li><a href="/">ホーム</a></li>
      <li>カテゴリ</li>
      <li aria-current="page">{categoryName}</li>
    </ol>
  </nav>

  <h1 class="page-heading">
    カテゴリ: {categoryName}
    <span class="taxonomy-count">（{posts.length}件）</span>
  </h1>

  <ul class="post-list">
    {posts.map(post => (
      <li class="post-card">
        <a href={`/${post.slug}/`} class="post-card-thumb-link" tabindex="-1" aria-hidden="true">
          {post.data.featured_image ? (
            <img
              src={r2ThumbUrl(post.data.featured_image!)}
              alt=""
              class="post-card-thumb"
              loading="lazy"
              width="120"
              height="80"
            />
          ) : (
            <div class="post-card-thumb post-card-thumb--placeholder">
              <span aria-hidden="true">🚲</span>
            </div>
          )}
        </a>
        <div class="post-card-body">
          <div class="post-card-meta">
            <span class="post-card-date">{formatDate(post.data.date)}</span>
            {(post.data.categories ?? []).map((cat: string) => (
              <a href={`/category/${toSlug(cat)}/`} class="post-card-cat">{cat}</a>
            ))}
          </div>
          <h2 class="post-card-title">
            <a href={`/${post.slug}/`}>{post.data.title}</a>
          </h2>
          {post.data.excerpt && (
            <p class="post-card-excerpt">{post.data.excerpt}</p>
          )}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
